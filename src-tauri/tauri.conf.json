{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StudyLog",
  "version": "3.2.0",
  "identifier": "com.studylog.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "학습기록",
        "width": 1040,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "visible": false
      },
      {
        "label": "timer",
        "title": "타이머",
        "width": 220,
        "height": 72,
        "minWidth": 120,
        "minHeight": 48,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false
      },
      {
        "label": "quickstart",
        "title": "빠른 시작",
        "width": 420,
        "height": 460,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "focus": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGNDM0MEEzREIzQjUzMUQKUldRZFV6dmJvMEJEcnprMDJEOXpMS3p5Rit5UGQ0cEhHSjRma0U0Z09IZndySENSeUhxREtvMzQK",
      "endpoints": [
        "https://github.com/pyjhoop/study-log/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
